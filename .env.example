# ------------------------------------------------------------------
# SecuritySIEM-AI — environment variables (Ahmad's config.py loads these)
# Copy to .env and fill in real values. Never commit the real .env file.
# ------------------------------------------------------------------

APP_ENV=development
LOG_LEVEL=INFO

# Security
SECRET_KEY=change-me-to-a-long-random-string

# AI / LLM
OPENAI_API_KEY=sk-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
LLM_PROVIDER=openai
LLM_MODEL=gpt-4o-mini
LLM_TEMPERATURE=0.0
LLM_REQUEST_TIMEOUT=20
INTENT_CONFIDENCE_THRESHOLD=0.7

# Data stores
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200
WAZUH_URL=https://localhost:55000

# Query generation defaults
DEFAULT_QUERY_SIZE=100
MAX_QUERY_SIZE=1000
DEFAULT_TIME_RANGE=past_24_hours