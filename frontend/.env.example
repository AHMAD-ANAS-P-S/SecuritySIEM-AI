# ==========================================
# SentinelAI - Environment Configuration
# Copy this file to .env and fill in values
# ==========================================

# API
VITE_API_BASE_URL=https://api.sentinelai.com/v1
VITE_API_TIMEOUT=15000

# Auth
VITE_AUTH_TOKEN_KEY=sentinelai_access_token
VITE_AUTH_REFRESH_TOKEN_KEY=sentinelai_refresh_token

# App
VITE_APP_NAME=SentinelAI
VITE_APP_ENV=development

# Feature Flags
VITE_ENABLE_ANALYTICS=false
VITE_ENABLE_MOCK_API=false

# Third-Party
VITE_SENTRY_DSN=
